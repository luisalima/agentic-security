            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"the-attack\">The Attack</h2>\n<span class=\"paragraph\">The user makes an innocent request. But the email they're asking about contains malicious instructions:</span></span>"
          }
        }
